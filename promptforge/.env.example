# Add API keys for providers you want to use (any or all)

# Native SDK providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# OpenAI-compatible providers (all use the same openai SDK with custom base_url)
GROQ_API_KEY=gsk_...
TOGETHER_API_KEY=...
FIREWORKS_API_KEY=...
OPENROUTER_API_KEY=sk-or-...

# No key needed for local models
# Ollama: http://localhost:11434/v1
# vLLM: http://localhost:8000/v1
